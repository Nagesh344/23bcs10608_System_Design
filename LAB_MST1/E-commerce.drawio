        <mxCell id="X7ljHbONGoLSiIeBwHvJ-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=14;" value="Design an E-Commerce system with following requirements:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;a).User login service&lt;/div&gt;&lt;div&gt;b).Search Service&lt;/div&gt;&lt;div&gt;c).Product catalog Service&lt;/div&gt;&lt;div&gt;d).Cart Service&lt;/div&gt;&lt;div&gt;e).Order Status service&lt;/div&gt;&lt;div&gt;f).checkout service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Optimise the product searching and inventroy stock management in real time.&lt;/div&gt;" vertex="1">
