        <mxCell id="X7ljHbONGoLSiIeBwHvJ-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=14;" value="&lt;font&gt;Functional Requirements:&lt;/font&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font&gt;User login/Sign up&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Product Search&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Add product to Cart&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Product Catalog(User shoukd&amp;nbsp; be able to see products)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;PLace an order&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Payment service&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="220" x="-2425" y="-4210" as="geometry" />
